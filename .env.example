# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Codemax API (OpenAI-compatible) — REQUIRED for LLM skill extraction
# Get your key from: https://api.codemax.pro (or your Anthropic account)
ANTHROPIC_API_KEY=your-codemax-api-key-here

# Optional: GitHub token for faster/more complete data fetching
# Generate at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Optional: Override model (defaults to claude-opus-4-6)
OPENAI_MODEL=claude-opus-4-6
